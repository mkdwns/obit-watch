# Copy this to .env and fill in your values

SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=you@gmail.com
SMTP_PASS=your-gmail-app-password
ALERT_FROM=you@gmail.com
ALERT_TO=you@gmail.com

# Daily scan time (24h)
SCAN_CRON_HOUR=6
SCAN_CRON_MINUTE=0

# Seconds between scrape requests
SCRAPE_DELAY=3

# SQLite path inside container
DB_PATH=/app/data/obit_watch.db

# ── Test obit server ─────────────────────────────────────────────────────
# Set to true to enable the fake obituary store for testing.
# The scraper will automatically query /api/test/obits/search when enabled.
TEST_OBITS_ENABLED=false

# URL of the running backend (used by scraper to reach test endpoint).
# In Docker this should be http://backend:8000; locally http://localhost:8000
TEST_SERVER_URL=http://localhost:8000
